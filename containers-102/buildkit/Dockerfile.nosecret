FROM cgr.dev/chainguard/python:latest-dev
WORKDIR /app
COPY requirements.txt .
ARG PIP_TOKEN
# The token value is baked into the image history — visible via `docker image history`
RUN echo "registry: https://token:${PIP_TOKEN}@pypi.company.internal/simple/" && \
    pip install --no-cache-dir -r requirements.txt
COPY . .
